function foo() {
    if (true) {
        stop
    }

    if (false) { $lib.print("no cover") } // pragma: no cover

    if (false) { // pragma: no cover start
        $lib.print("multi-line no cover")
    } // pragma: no cover stop

    if (false) { $lib.print("stop before start") } // pragma: no cover stop

    if (false) { // pragma: no cover start
        $lib.print("start in a block") // pragma: no cover start
    } // pragma: no cover stop
}
yield $foo()
// coverage: 1, 2, 3,     18
// lines:    1, 2, 3, 12, 18
