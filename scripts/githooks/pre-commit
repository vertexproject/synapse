#!/usr/bin/env python
"""
Copy this file to .git/hooks/pre-commit in order to have the hooks run when doing a git commit action.

Requires ruff and nbstripout to be installed.

Forked from https://gist.github.com/810399
Updated from https://github.com/cbrueffer/pep8-git-hook
"""
from __future__ import print_function
import os
import shutil
import subprocess
import sys
import tempfile

def system(*args, **kwargs):
    kwargs.setdefault('stdout', subprocess.PIPE)
    kwargs.setdefault('encoding', 'utf-8')
    proc = subprocess.run(args, **kwargs)
    return proc.returncode, proc.stdout, proc.stderr

def main():
    lint_python()

def lint_python():
    gitdir = system('git', 'rev-parse', '--show-toplevel')[1].strip()
    files = system('git', 'diff', '--cached', '--name-only')[1]
    pyfiles = [file.strip() for file in files.split('\n') if file.strip().endswith('.py')]
    nbfiles = [os.path.join(gitdir, file.strip()) for file in files.split('\n') if file.strip().endswith('.ipynb')]

    all_files = pyfiles + nbfiles

    if not all_files:
        sys.exit(0)

    if pyfiles:
        tempdir = tempfile.mkdtemp()
        for name in pyfiles:
            filename = os.path.join(tempdir, name)
            filepath = os.path.dirname(filename)

            if not os.path.exists(filepath):
                os.makedirs(filepath)
            with open(filename, 'w') as f:
                system('git', 'show', ':' + name, stdout=f)

        args = ['ruff', 'check', f'--config={gitdir}/pyproject.toml']
        args.append('.')
        code, stdout, stderr = system(*args, cwd=tempdir)
        shutil.rmtree(tempdir)
        if code != 0:
            print('Style violations have been detected.  Please fix them\n'
                  'or force the commit with "git commit --no-verify".\n')
            print(stdout)
            sys.exit(1)
    if nbfiles:
        print('Ipython notebooks detected - stripping their output automatically and re-adding them.')
        stdout = system('nbstripout', '--help')[1]
        if 'notebook' in stdout:
            for nbfp in nbfiles:
                nbfp = os.path.join(gitdir, nbfp)
                args = ['nbstripout', nbfp]
                system(*args)
                args = ['git', 'add', nbfp]
                system(*args)
        else:
            print('nbstripout not installed - skipping notebook normalization.')

    sys.exit(0)

if __name__ == '__main__':
    main()
